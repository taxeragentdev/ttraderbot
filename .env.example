# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_from_@BotFather
TELEGRAM_CHAT_ID=your_chat_id

# Trading Symbols (comma separated, no spaces)
TRADING_SYMBOLS=BTC,ETH,SOL,HYPE,SUI,VIRTUAL,ASTER

# Chart Timeframe: 1m, 5m, 15m, 1h, 4h, 1d
TIMEFRAME=5m

# Signal Thresholds (0-100)
# Higher = fewer but stronger signals; Lower = more signals but some may be weak
MIN_SIGNAL_STRENGTH=60
MIN_SIGNAL_CONFIDENCE=40

# Railway Webhook (optional, for webhook mode)
# WEBHOOK_URL=https://your-app.up.railway.app
# PORT=3000
